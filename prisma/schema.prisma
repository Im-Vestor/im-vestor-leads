generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ENTREPRENEUR
  INVESTOR
  ADMIN
}

enum NotificationType {
  MESSAGE_RECEIVED
}

enum Sector {
  TECHNOLOGY
  HEALTHCARE
  FINTECH
  EDTECH
  CLEANTECH
  ECOMMERCE
  SAAS
  AGRITECH
  PROPTECH
  BIOTECH
}

enum InvestmentRange {
  R_10K_50K   @map("10K-50K")
  R_50K_200K  @map("50K-200K")
  R_200K_500K @map("200K-500K")
  R_500K_1M   @map("500K-1M")
  R_1M_5M     @map("1M-5M")
  R_5M_PLUS   @map("5M+")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Currency {
  USD
  EUR
  BRL
}

enum ProjectMediaType {
  PHOTO
  VIDEO
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  name         String?
  country      String?
  role         UserRole @default(ENTREPRENEUR)
  referralCode String   @unique

  referredByCode String?
  referrer       User?   @relation("Referrals", fields: [referredByCode], references: [referralCode])
  referrals      User[]  @relation("Referrals")

  investmentCapacity InvestmentRange?
  sectors            Sector[]

  pokes              Int       @default(2)
  leadCredits        Int       @default(1)
  hypertrainTickets  Int       @default(0)
  hypertrainUntil    DateTime?
  subscriptionPlan   String?
  subscriptionStatus String?
  stripeCustomerId   String?   @unique
  pokeSubCreditedAt  DateTime?
  pokeCycleHigh      Int       @default(0)

  lastSeenAt DateTime?

  sentMessages     Message[]       @relation("SentMessages")
  conversations    Conversation[]  @relation("ConversationParticipants")
  notifications    Notification[]  @relation("UserNotifications")
  projects         Project[]       @relation("EntrepreneurProjects")
  unlockedProjects ProjectUnlock[] @relation("UserUnlocks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("ConversationParticipants")

  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  senderId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, readAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  type      NotificationType
  read      Boolean          @default(false)
  userId    String
  senderId  String?
  message   String?
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model ProcessedStripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  @@map("processed_stripe_events")
}

model Area {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[]

  @@map("areas")
}

model Project {
  id              String        @id @default(cuid())
  name            String
  quickSolution   String?
  about           String?
  website         String?
  country         String?
  status          ProjectStatus @default(DRAFT)
  currency        Currency      @default(EUR)
  investmentGoal  Int
  startInvestment Int?
  equity          Float?
  annualRevenue   Int?
  monthsToReturn  Int?
  investorSlots   Int?
  logo            String?
  videoPitchUrl   String?
  hypertrainUntil DateTime?

  areas Area[]

  entrepreneurId String
  entrepreneur   User   @relation("EntrepreneurProjects", fields: [entrepreneurId], references: [id], onDelete: Cascade)

  media   ProjectMedia[]
  unlocks ProjectUnlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entrepreneurId])
  @@index([status, createdAt])
  @@map("projects")
}

// An investor permanently unlocking a project's full profile, spending one lead credit.
model ProjectUnlock {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation("UserUnlocks", fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_unlocks")
}

model ProjectMedia {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      ProjectMediaType
  url       String
  caption   String?
  order     Int              @default(0)

  @@index([projectId])
  @@map("project_media")
}

model BannedWord {
  id        String   @id @default(cuid())
  word      String   @unique
  createdAt DateTime @default(now())
  createdBy String

  @@index([word])
  @@map("banned_words")
}
